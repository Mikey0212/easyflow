# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf
*.bash text eol=lf

# Config/data files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.js text eol=lf

# Special files
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
